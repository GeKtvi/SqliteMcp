{
  "DefaultDbPath": "",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "SqliteMcp": "Information",
      "SqliteMcp.Hooks": "Information"
    },
    "File": {
      "Path": "logs/sqlite-mcp.log",
      "Append": true,
      "MinLevel": "Information",
      "FileSizeLimitBytes": 5242880,
      "MaxRollingFiles": 5
    }
  },
  "Hooks": {
    "Open": {
      "Before": "",
      "After": ""
    },
    "Close": {
      "Before": "",
      "After": ""
    },
    "CloseAll": {
      "Before": "",
      "After": ""
    },
    "Query": {
      "Before": "",
      "After": ""
    }
  }
}
